{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GrammarFix",
  "version": "1.0.0",
  "identifier": "dev.grammarfix.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "GrammarFix",
        "width": 440,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
